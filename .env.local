# Local development with Docker
# Database configuration for docker-compose PostgreSQL
DATABASE_URL="postgresql://user:password@db:5432/workout"
DIRECT_URL="postgresql://user:password@db:5432/workout"

# Clerk Authentication Keys (for development)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_local_key
CLERK_SECRET_KEY=sk_test_your_local_key

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Next.js environment
NODE_ENV=development
